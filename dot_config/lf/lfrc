#
### allows use of environment variables in cmd or mapping
cmd eval &{{
    cmd="send $id"
    for arg; do
        cmd="$cmd $(eval "printf '%q' \"$arg\"")"
    done
    lf -remote "$cmd"
}}

eval map g. cd "$OLDPWD"

